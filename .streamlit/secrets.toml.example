# Copy this file to `.streamlit/secrets.toml` for LOCAL testing against a database,
# OR paste the same key into the Streamlit Community Cloud "Secrets" box when deploying.
# The real secrets.toml is gitignored — never commit your connection string.
#
# Use your Neon/Supabase POOLED connection string (must include sslmode=require).

DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
